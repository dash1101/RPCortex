# ── Runtime data — generated on device, not source code ───────────
# POST and setup_seq() recreate all of this on first boot.
# Do not include these directories in the repo.
/Nebula/
/Users/

# ── Packages: track the BUILT-IN package sources, ignore the rest ──
# The built-ins are bundled into the .rpc by build.py, so their source must
# live in version control (a clean clone has to be able to build a complete
# image). Everything else under /Packages is runtime-installed on the device.
# NOTE: the *.mpy rule below still ignores any compiled copies inside these.
/Packages/*
!/Packages/Launchpad
!/Packages/Editor
!/Packages/PicoFetch
!/Packages/NTP
!/Packages/RPCMark

# ── Python / MicroPython bytecode ────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.mpy

# ── Build outputs (local .rpc release archives) ───────────────────
*.rpc

# ── OS / editor junk ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── IDE project files ─────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Secrets / environment ─────────────────────────────────────────
.env
.env.*
secrets.*

# Generated build stamp (build.py)
Core/buildinfo.py

# Generated bundled repo index (build.py)
Core/default_repo.json
.aider*
